FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    jq \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    pandas \
    numpy \
    matplotlib \
    seaborn \
    scikit-learn \
    scipy \
    requests \
    beautifulsoup4 \
    pyyaml \
    openpyxl \
    tabulate

WORKDIR /workspace

CMD ["tail", "-f", "/dev/null"]
