# Required
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# Sandbox
SANDBOX_PROVIDER=boxlite          # boxlite | e2b
E2B_API_KEY=                      # Required when SANDBOX_PROVIDER=e2b

# Optional (defaults shown)
ANTHROPIC_BASE_URL=https://api.anthropic.com
REDIS_URL=redis://localhost:6379
PLANNING_MODEL=claude-sonnet-4-20250514
TASK_MODEL=claude-sonnet-4-20250514
MAX_ITERATIONS=50
MAX_TOKENS=8192
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
